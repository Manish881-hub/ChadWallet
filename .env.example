# Privy Authentication (required)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=
# Optional when you want to pin token verification to a dashboard-provided key
# PRIVY_JWT_VERIFICATION_KEY=

# Birdeye API for market data (required)
NEXT_PUBLIC_BIRDEYE_API_KEY=

# Alchemy Solana RPC (required)
NEXT_PUBLIC_ALCHEMY_RPC=

# Supabase profile persistence (required when persistence is enabled)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy Supabase anon key name, only needed if you keep older client code around
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: custom API base URL (defaults to localhost:3001)
# NEXT_PUBLIC_API_URL=
